rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      
      // 1. Read: Allow any authenticated user
      allow read: if request.auth != null;

      // 2. Write: Allow any authenticated user (removed 'authorized' custom claim check)
      // Enforce 20MB size limit
      allow write: if request.auth != null 
                   && (request.resource == null || request.resource.size < 20 * 1024 * 1024);
    }
  }
}